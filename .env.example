# ArbitrageX Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# PUBLIC VARIABLES (Safe for client-side, will be exposed in browser)
# ============================================================================

# WalletConnect Project ID - Get one at https://cloud.walletconnect.com/
# Required for RainbowKit wallet connection
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Optional: Infura API Key for better RPC reliability
# Get one at https://infura.io/
NEXT_PUBLIC_INFURA_API_KEY=your_infura_api_key_here

# Optional: Alchemy API Key as backup RPC
# Get one at https://www.alchemy.com/
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here

# ============================================================================
# SECRET VARIABLES (Never expose to client, server-side only)
# ============================================================================

# These would be used for backend API routes if needed
# Never commit actual values to git

# Example: Private key for bot operations (DO NOT USE IN FRONTEND)
# BOT_PRIVATE_KEY=never_store_private_keys_in_client_code

# Example: API keys for external services (use server-side routes)
# SERVICE_API_KEY=use_server_api_routes_for_secrets
